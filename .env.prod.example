# ============================================================
# 生产环境变量样例（阿里云部署用）
# 用法：在服务器上 cp .env.prod.example .env，改下面两处带 <> 的值
# ============================================================

# ---------- Postgres ----------
POSTGRES_USER=meeting
POSTGRES_PASSWORD=<改成一个强密码>
POSTGRES_DB=meeting
DATABASE_URL=postgresql://meeting:<上面那个强密码>@postgres:5432/meeting

# ---------- Redis / Qdrant（容器内部地址，照填即可） ----------
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

# ---------- 全部走通义（DashScope，复用百炼 key） ----------
ASR_PROVIDER=dashscope
EMBEDDING_PROVIDER=dashscope
RERANK_PROVIDER=dashscope
LLM_PROVIDER=dashscope
LLM_MODEL=qwen-plus
DASHSCOPE_API_KEY=<你的百炼 key，sk- 开头>

STORAGE_DIR=storage
