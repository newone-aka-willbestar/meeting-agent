# ============================================================
# 会议数字员工 · 环境变量样例
# 用法：复制本文件为 .env，按需填值。.env 不入库（见 .gitignore）。
# P0 阶段不填 LLM/ASR 的 key 也能把骨架跑起来。
# ============================================================

# ---------- Postgres（会议/待办/元数据） ----------
POSTGRES_USER=meeting
POSTGRES_PASSWORD=meeting_pw
POSTGRES_DB=meeting
# backend 容器内连 postgres 用服务名 "postgres" 当主机名
DATABASE_URL=postgresql://meeting:meeting_pw@postgres:5432/meeting

# ---------- Redis（缓存 / 异步转写任务队列） ----------
REDIS_URL=redis://redis:6379/0

# ---------- Qdrant（历史会议向量库） ----------
QDRANT_URL=http://qdrant:6333

# ---------- Langfuse（可观测，P3 才真正接） ----------
# 浏览器访问 Langfuse 控制台的地址
LANGFUSE_NEXTAUTH_URL=http://localhost:3000
# 下面两个是 Langfuse 自己加密用的盐和密钥，本地随便填够长即可
LANGFUSE_NEXTAUTH_SECRET=change-me-dev-secret-please
LANGFUSE_SALT=change-me-dev-salt-please
# backend 上报 trace 用的 key（P3 在 Langfuse 控制台里生成后再填）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# ---------- LLM（抽取/纪要/周报，可配置切换） ----------
# 默认走 DeepSeek 或 通义千问，二选一，P2 才真正用到
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ---------- ASR（语音转写） ----------
# provider: mock（假数据，先跑通用）/ dashscope（阿里云通义，需填 key）
ASR_PROVIDER=mock
# 阿里云百炼 API key（形如 sk-xxx），用 dashscope 时必填
ASR_API_KEY=

# ---------- 检索：Embedding / Rerank ----------
# mock=轻量假向量先跑通；dashscope=阿里云真实语义向量/重排（需下方 key）
EMBEDDING_PROVIDER=mock
RERANK_PROVIDER=mock
# 阿里云百炼 key（embedding/rerank 用，通常和 ASR_API_KEY 同一个）
DASHSCOPE_API_KEY=

# ---------- 上传文件落盘目录（容器内路径） ----------
STORAGE_DIR=storage
